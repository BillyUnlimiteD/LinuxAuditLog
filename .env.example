# LinuxAuditLog -- Plantilla de variables de entorno
# Copia este archivo a .env y rellena con tus credenciales reales:
#   cp .env.example .env      (Linux/macOS/WSL)
#   copy .env.example .env    (Windows CMD)

# -- Conexion SSH (obligatorias) ----------------------------------------------
SSH_HOST=192.168.1.100
SSH_USER=admin
SSH_PASS=tu_contrasena_aqui
SSH_PORT=22

# -- Ventana de analisis ------------------------------------------------------
# Cuantas horas hacia atras recolectar logs (por defecto 72)
#TIME_WINDOW_HOURS=72

# Maximo de lineas por fuente de log (por defecto 50000)
#LOG_MAX_LINES=50000

# -- Timeouts SSH (segundos) --------------------------------------------------
#SSH_CONNECT_TIMEOUT=30
#SSH_COMMAND_TIMEOUT=60
#SSH_LARGE_TIMEOUT=120

# -- Rutas de salida (por defecto relativas al proyecto) ----------------------
# Util si quieres guardar los jobs en un disco externo o ruta especifica
#JOBS_DIR=/ruta/personalizada/jobs
#RULES_DIR=/ruta/personalizada/rules

# -- Entorno de ejecucion -----------------------------------------------------
# Carpeta donde se descarga uv y Python (por defecto: <proyecto>/.tools/)
# Se rellena automaticamente en la primera ejecucion.
TOOLS_DIR=

# Version de Python a instalar via uv (por defecto: 3.11)
PYTHON_VERSION=3.11

# Ruta absoluta al interprete Python local.
# Se rellena automaticamente en la primera ejecucion.
# Para resetear en un equipo nuevo: dejar vacio o borrar la linea.
PYTHON_PATH=

# Ruta absoluta al entorno virtual.
# Se rellena automaticamente en la primera ejecucion.
# Para resetear en un equipo nuevo: dejar vacio o borrar la linea.
VENV_PATH=
